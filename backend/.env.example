# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# === LLM ===
# Leave OPENAI_API_KEY blank/placeholder to run fully local on Ollama (free).
# To use GPT-4o instead, paste a real sk-... key.
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o
LLM_FALLBACK=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest

# === DATABASES === (change all default passwords for any non-local deployment)
POSTGRES_URL=postgresql://gyanvriksh:CHANGE_ME@localhost:5432/gyanvriksh
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME
QDRANT_HOST=localhost
QDRANT_PORT=6333
REDIS_URL=redis://localhost:6379/0

# === KAFKA ===
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW_DOCS=raw-documents
KAFKA_TOPIC_OCR_COMPLETE=ocr-complete
KAFKA_TOPIC_ENTITIES_RAW=entities-raw
KAFKA_TOPIC_ENTITIES_TAGGED=entities-tagged

# === OBJECT STORAGE ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET_DOCS=gyanvriksh-docs
MINIO_BUCKET_AUDIO=gyanvriksh-audio

# === AUTH === (generate a strong random 32+ char secret: `openssl rand -hex 32`)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_SECRET
JWT_EXPIRE_HOURS=24

# === MODELS ===
NER_MODEL_PATH=./models/ner_model
EMBEDDING_MODEL=BAAI/bge-m3
WHISPER_MODEL=large-v3
NER_BACKEND=bert
EMBEDDING_BACKEND=minilm

# === APP ===
ENVIRONMENT=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173
MAX_UPLOAD_SIZE_MB=100
CHUNK_SIZE=512
CHUNK_OVERLAP=80
